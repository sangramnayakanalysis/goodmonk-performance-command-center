# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.
# In GitHub Actions, these same names are set as repository Secrets instead
# (see .github/workflows/monitor.yml) — .env is only used for local runs.

# --- GTmetrix -----------------------------------------------------------
GTMETRIX_API_KEY=your_gtmetrix_api_key_here
GTMETRIX_LOCATION=24
GTMETRIX_BROWSER=3

# --- Networking / retries --------------------------------------------------
REQUEST_TIMEOUT_SECONDS=30
API_MAX_RETRIES=3
API_RETRY_BASE_DELAY_SECONDS=3
RATE_LIMIT_WAIT_SECONDS=30
POLL_MAX_ATTEMPTS=24
POLL_INTERVAL_SECONDS=15
MAX_WORKERS=4

# --- Google Sheets -----------------------------------------------------------
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Local development: path to a downloaded service-account key file.
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
# CI (GitHub Actions): paste the whole JSON key content into a repo secret
# named GOOGLE_SERVICE_ACCOUNT_JSON instead — leave this blank locally.
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Email (optional — leave blank to disable email reports) ---------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# --- Alert thresholds --------------------------------------------------
ALERT_SCORE_THRESHOLD=80
ALERT_LCP_THRESHOLD_SECONDS=2.5
